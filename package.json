{
  "name": "philosophy-auto-chess",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "set WRANGLER_LOG_PATH=.wrangler/wrangler.log&& vinext dev",
    "build": "set WRANGLER_LOG_PATH=.wrangler/wrangler.log&& vinext build",
    "build:pages": "vite build --config vite.pages.config.ts",
    "start": "set WRANGLER_LOG_PATH=.wrangler/wrangler.log&& vinext start",
    "typecheck": "tsc --noEmit",
    "typecheck:tools": "tsc --noEmit -p tsconfig.tools.json",
    "test": "npm run typecheck && npm run typecheck:tools && npm run lint && npm run build && node --import tsx --test tests/game-engine.test.ts tests/rendered-html.test.mjs",
    "test:browser": "node tests/browser-interactions.mjs",
    "test:pages": "npm run build:pages && node tests/pages-smoke.mjs",
    "test:release": "node tests/release-smoke.mjs",
    "package:release": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/package-demo.ps1",
    "generate:audio": "node scripts/generate-audio-assets.mjs",
    "balance:sim": "node --import tsx scripts/balance-sim.ts",
    "economy:sim": "node --import tsx scripts/economy-sim.ts",
    "history:sim": "node --import tsx scripts/historical-event-sim.ts",
    "export:map-art": "node --import tsx scripts/export-map-art-package.ts",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern dist-pages --ignore-pattern .next",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-loading-skeleton": "3.5.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
